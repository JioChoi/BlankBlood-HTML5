function mbtext_setfont(argument0, argument1, argument2) {
	{
	   /********************************************************************************
	    * (ver 1.4.0)
	    * mbtext_setfont(spr_zen, spr_han, size)
	    *
	    * 锟絜锟絃锟絏锟絞锟絗锟斤拷p锟教僼锟紿锟斤拷锟絞(锟絏锟絭锟斤拷锟紺锟絞)锟狡僒锟紺锟結锟斤拷輶鑲凤拷锟紹
	    * mbtext_draw()锟斤拷膫褟o锟斤拷锟絆锟缴昁锟斤拷锟斤拷锟教娭愶拷锟斤拷锟斤拷s锟斤拷锟侥傦拷锟斤拷锟斤拷锟狡丅
	    *
	    * -sprite spr_zen  :锟絊锟絧锟斤拷锟斤拷锟絧锟教僗锟絭锟斤拷锟紺锟絞
	    * -sprite spr_han  :锟斤拷锟絧锟斤拷锟斤拷锟絧锟教僗锟絭锟斤拷锟紺锟絞
	    * -int    size     :1锟斤拷锟斤拷锟斤拷锟斤拷锟斤拷虄s锟絅锟絑锟斤拷锟斤拷锟紹
	    *                   锟絏锟絭锟斤拷锟紺锟絞锟缴嶏拷锟巾偣锟侥愶拷锟絤锟缴巜锟借偟锟饺傦拷锟狡昤锟斤拷艂锟斤拷葌锟斤拷葌锟紹
	    *
	    * return           :锟竭傦拷l锟斤拷锟斤拷
	    ********************************************************************************/
	   global.sprite_for_mb_zen = argument0;    // 锟絊锟絧锟斤拷锟斤拷锟絧sprite
	   global.sprite_for_mb_han = argument1;    // 锟斤拷锟絧锟斤拷锟斤拷锟絧sprite
	   global.mbchar_size = argument2;          // 1锟斤拷锟斤拷锟斤拷锟斤拷锟斤拷虄T锟紺锟結锟紹锟斤拷锟絧锟斤拷锟斤拷锟教夛拷锟斤拷锟酵傦拷锟斤拷1/2
	   exit;
	}



}
