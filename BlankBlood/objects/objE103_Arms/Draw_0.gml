switch(motion){
	case 0: draw_sprite_ext(global.SprEBoss_Part[1],-1,x,y,image_xscale,image_yscale,image_angle,image_blend,image_alpha);break;
	case 1: draw_sprite_ext(global.SprEBoss_Part[2],-1,x,y,image_xscale,image_yscale,image_angle,image_blend,image_alpha);break;
	case 2: draw_sprite_ext(global.SprEBoss_Part[3],-1,x,y,image_xscale,image_yscale,image_angle,image_blend,image_alpha);break;
	case 3: draw_sprite_ext(global.SprEBoss_Part[4],-1,x,y,image_xscale,image_yscale,image_angle,image_blend,image_alpha);break;
	case 4: draw_sprite_ext(global.SprEBoss_Part[5],-1,x,y,image_xscale,image_yscale,image_angle,image_blend,image_alpha);break;
}
